# ─── App ─────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Admin ────────────────────────────────────────
# Set a strong secret token for admin API access
ADMIN_TOKEN=change-this-to-a-long-random-secret
NEXT_PUBLIC_ADMIN_TOKEN=change-this-to-a-long-random-secret

# ─── Email (SMTP) ─────────────────────────────────
# Use Gmail, Resend, Brevo, or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email to receive admin notifications for new orders
ADMIN_EMAIL=admin@yourdomain.com

# ─── WhatsApp ─────────────────────────────────────
# Phone number in international format (no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=213500000000

# ─── Webhook (n8n / Zapier / Make) ────────────────
# POST new order data to this URL on every order
WEBHOOK_URL=https://your-n8n.com/webhook/orders
WEBHOOK_SECRET=your-webhook-secret

# ─── Security ─────────────────────────────────────
ADMIN_SALT=some-random-salt-string
